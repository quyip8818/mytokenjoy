+func RegenerateToken(c *gin.Context) {
+	id, err := strconv.Atoi(c.Param("id"))
+	if err != nil {
+		common.ApiError(c, err)
+		return
+	}
+	role := c.GetInt("role")
+	var token *model.Token
+	if role >= common.RoleAdminUser {
+		token, err = model.RegenerateTokenKey(id)
+	} else {
+		userId := c.GetInt("id")
+		existing, getErr := model.GetTokenByIds(id, userId)
+		if getErr != nil {
+			common.ApiError(c, getErr)
+			return
+		}
+		token, err = model.RegenerateTokenKey(existing.Id)
+	}
+	if err != nil {
+		common.ApiError(c, err)
+		return
+	}
+	common.ApiSuccess(c, token)
+}
