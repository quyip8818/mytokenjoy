+func resolveTokenOwnerID(c *gin.Context, requestedUserID int) (int, error) {
+	callerID := c.GetInt("id")
+	role := c.GetInt("role")
+	if role < common.RoleAdminUser || requestedUserID <= 0 {
+		return callerID, nil
+	}
+	user, err := model.GetUserById(requestedUserID, false)
+	if err != nil {
+		return 0, err
+	}
+	if !canManageTargetRole(role, user.Role) {
+		return 0, fmt.Errorf("no permission to create token for user %d", requestedUserID)
+	}
+	return requestedUserID, nil
+}
