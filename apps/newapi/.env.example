# New API Relay local stack
# Relay public URL: http://localhost:3000
# Admin API: http://localhost:3000/api
# Management webhook target: http://localhost:8080/api/internal/webhooks/newapi-log
#
# Postgres (single instance, two databases):
#   tokenjoy  -> Backend DATABASE_URL
#   newapi    -> NewAPI SQL_DSN (docker-compose sets this for the new-api service)

NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
NEW_API_ADMIN_TOKEN=replace-with-admin-jwt-after-bootstrap
NEW_API_BASE_URL=http://localhost:3000
NEW_API_PUBLIC_URL=http://localhost:3000
NEW_API_ENABLED=true

DATABASE_URL=postgres://tokenjoy:tokenjoy@localhost:5432/tokenjoy?sslmode=disable
NEW_API_SQL_DSN=postgresql://tokenjoy:tokenjoy@localhost:5432/newapi?sslmode=disable
