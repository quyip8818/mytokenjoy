# New API Relay local stack
# Relay public URL: http://localhost:3000
# Admin API: http://localhost:3000/api
#
# Postgres (single instance, three databases):
#   tokenjoy -> Backend DATABASE_URL
#   newapi   -> NewAPI SQL_DSN (users, tokens, channels)
#   logs     -> NewAPI LOG_SQL_DSN + Backend LOG_DATABASE_URL
#
# NewAPI settle notify (P1 patch): POST {"log_id"} to Backend after consume log insert.
# Set in docker-compose for the new-api service; empty URL disables notify (reconcile still ingests).
MANAGEMENT_WEBHOOK_URL=http://localhost:8080/api/internal/webhooks/newapi-log
MANAGEMENT_WEBHOOK_SECRET=tokenjoy-webhook-secret

NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
NEW_API_ADMIN_TOKEN=replace-with-admin-jwt-after-bootstrap
NEW_API_BASE_URL=http://localhost:3000
NEW_API_PUBLIC_URL=http://localhost:3000
NEW_API_ENABLED=true

DATABASE_URL=postgres://tokenjoy:tokenjoy@localhost:5432/tokenjoy?sslmode=disable
LOG_DATABASE_URL=postgres://tokenjoy:tokenjoy@localhost:5432/logs?sslmode=disable
NEW_API_SQL_DSN=postgresql://tokenjoy:tokenjoy@localhost:5432/newapi?sslmode=disable
NEW_API_LOG_SQL_DSN=postgresql://tokenjoy:tokenjoy@localhost:5432/logs?sslmode=disable&search_path=newapi
