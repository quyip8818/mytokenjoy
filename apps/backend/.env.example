DATABASE_URL=postgres://tokenjoy:tokenjoy@127.0.0.1:5432/tokenjoy?sslmode=disable
PORT=8080
CORS_ORIGINS=http://localhost:5173
APP_PROFILE=demo
DEMO_TODAY=2026-06-19
SIMULATE_DELAY=true

# 私有化部署必填；SaaS 模式下忽略，固定为 Test Company
COMPANY_NAME=Demo Company

# 企业面 Session JWT 签名（必填）
SESSION_SECRET=change-me-in-production

# NewAPI / Relay（默认关闭）
# NEW_API_ENABLED=false
# NEW_API_BASE_URL=http://127.0.0.1:3000
# NEW_API_ADMIN_TOKEN=
# NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
# RELAY_GATEWAY_ENABLED=false

# 组织同步（可选）
# SYNC_TRIGGER_API_KEY=
# DATA_SOURCE_CREDENTIAL_KEY=
# FEISHU_BASE_URL=https://open.feishu.cn
# NOTIFY_WEBHOOK_URL=

# Worker
# WORKER_POLL_INTERVAL_SEC=5
# WORKER_ORG_SYNC_INTERVAL_SEC=60

# Ingest (shared logs DB; requires NEW_API_WEBHOOK_SECRET when enabled)
# LOG_DATABASE_URL=postgres://tokenjoy:tokenjoy@127.0.0.1:5432/logs?sslmode=disable
# NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
# INGEST_RECONCILE_INTERVAL_SEC=300
# INGEST_RECONCILE_BATCH_SIZE=500
# INGEST_RECONCILE_MAX_ROUNDS=10
# INGEST_FAILURE_BATCH_SIZE=20

# SaaS 多企业（私有化默认关闭）
# SUPPORT_SAAS=false
# TOKENJOY_COMPANY_ID=1
# LOCAL_COMPANY_ID=2
# DEFAULT_COMPANY_ID=2
# COMPANY_WALLET_CACHE_TTL_SEC=30
# PLATFORM_SHARED_RELAY_GROUP=platform_shared
# PLATFORM_BOOTSTRAP_EMAIL=
# PLATFORM_BOOTSTRAP_PASSWORD=
