DATABASE_URL=postgres://tokenjoy:tokenjoy@127.0.0.1:5432/tokenjoy?sslmode=disable
PORT=8080
CORS_ORIGINS=http://localhost:5173
DEPLOY_ENV=local
BOOTSTRAP_MODE=demo
CLOCK_ANCHOR=2026-06-19
SECURE_COOKIE=false
SIMULATE_DELAY=true

# 私有化部署必填；SaaS 模式下忽略，固定为 Test Company
COMPANY_NAME="Demo Company"

# 企业面 Session JWT 签名（必填）
SESSION_SECRET=change-me-in-production

# 数据源凭证加密密钥（必填，32 字节 hex 或 base64）
DATA_SOURCE_CREDENTIAL_KEY=dGV2LWNyZWRlbnRpYWwta2V5LWZvci1sb2NhbC1kZXY=

# NewAPI / Gateway（默认关闭）
# NEW_API_ENABLED=false
# NEW_API_BASE_URL=http://127.0.0.1:3000
# NEW_API_ADMIN_TOKEN=
# NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
# NEW_API_GATEWAY_ENABLED=false

# 组织同步（可选）
# SYNC_TRIGGER_API_KEY=
# FEISHU_BASE_URL=https://open.feishu.cn
# NOTIFY_WEBHOOK_URL=

# Worker
# WORKER_POLL_INTERVAL_SEC=5
# WORKER_ORG_SYNC_INTERVAL_SEC=60

# Ingest (shared logs DB; requires NEW_API_WEBHOOK_SECRET when enabled)
# LOG_DATABASE_URL=postgres://tokenjoy:tokenjoy@127.0.0.1:5432/logs?sslmode=disable
# NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
# INGEST_RECONCILE_INTERVAL_SEC=300
# INGEST_RECONCILE_BATCH_SIZE=500
# INGEST_RECONCILE_MAX_ROUNDS=10
# INGEST_JOB_BATCH_SIZE=20

# SIMULATE_DELAY=false

# Full-stack integration verify（pnpm verify:gate / pnpm verify:integration）
# 复制以下块到 .env；verify:integration 还需 NEW_API_ADMIN_TOKEN（Rotate/Revoke 的 NewAPI Admin 断言）
# NEW_API_ENABLED=true
# NEW_API_GATEWAY_ENABLED=true
# NEW_API_BASE_URL=http://127.0.0.1:3000
# NEW_API_ADMIN_TOKEN=
# NEW_API_WEBHOOK_SECRET=tokenjoy-webhook-secret
# LOG_DATABASE_URL=postgres://tokenjoy:tokenjoy@127.0.0.1:5432/logs?sslmode=disable
# BOOTSTRAP_MODE=demo
# SIMULATE_DELAY=false

# SaaS 多企业（私有化默认关闭）
# SUPPORT_SAAS=false
# TOKENJOY_COMPANY_ID=1
# LOCAL_COMPANY_ID=2
# DEFAULT_COMPANY_ID=2
# COMPANY_WALLET_CACHE_TTL_SEC=30
# PLATFORM_SHARED_NEW_API_GROUP=platform_shared
# PLATFORM_BOOTSTRAP_EMAIL=
# PLATFORM_BOOTSTRAP_PASSWORD=

# 生产部署示例（DEPLOY_ENV=production 时 validate 强制以下组合）：
# DEPLOY_ENV=production
# BOOTSTRAP_MODE=none
# SECURE_COOKIE=true
# NEW_API_ENABLED=true
# NEW_API_GATEWAY_ENABLED=true
# LOG_DATABASE_URL=postgres://...
# NEW_API_WEBHOOK_SECRET=...
# SIMULATE_DELAY=false
