# Copy to apps/backend/.env — secrets and personal overrides only.
# `make start` loads .env.development first, then .env (later wins).
#
# After `pnpm docker:reset`, bootstrap writes a fresh token automatically.
# Re-run manually: pnpm bootstrap  or  pnpm bootstrap -- --token-only

NEW_API_ADMIN_TOKEN=

# NewAPI root user id for Bearer admin calls (default 1 after local setup)
# NEW_API_ADMIN_USER_ID=1

# Optional overrides (defaults are in .env.development):
# SESSION_SECRET=
# SIMULATE_DELAY=false

# 组织同步（可选）
# SYNC_TRIGGER_API_KEY=
# FEISHU_BASE_URL=https://open.feishu.cn
# NOTIFY_WEBHOOK_URL=

# Worker
# WORKER_POLL_INTERVAL_SEC=1
# RIVER_PERIODIC_ENABLED=true          # tenant_watchdog Periodic（默认 true）
# WATCHDOG_INTERVAL_SEC=604800
# WATCHDOG_STARTUP_DELAY_SEC=5         # 进程启动后延迟跑首次 due 扫描，不挡 health/readiness
# WATCHDOG_BULK_BATCH_SIZE=200

# GatewayBudgetCheck 软挡（可选，默认关）：设置 REDIS_URL 开启，miss 降级放行、不回源 PG
# 本地：pnpm start:redis 后 REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL=
# GATEWAY_BUDGET_CHECK_TTL_SEC=600

# Ingest tuning
# INGEST_RECONCILE_INTERVAL_SEC=300
# INGEST_RECONCILE_BATCH_SIZE=500
# INGEST_RECONCILE_MAX_ROUNDS=10
# INGEST_JOB_BATCH_SIZE=20

# SaaS 多企业（私有化默认关闭）
# SUPPORT_SAAS=false
# TOKENJOY_COMPANY_ID=1
# LOCAL_COMPANY_ID=2
# COMPANY_WALLET_CACHE_TTL_SEC=30
# PLATFORM_SHARED_NEW_API_GROUP=platform_shared
# PLATFORM_BOOTSTRAP_EMAIL=
# PLATFORM_BOOTSTRAP_PASSWORD=

# 生产部署（DEPLOY_ENV=production 时 validate 强制）：
# DEPLOY_ENV=production
# BOOTSTRAP_MODE=none
# SECURE_COOKIE=true
# DATABASE_URL=postgres://...
# LOG_DATABASE_URL=postgres://...
# NEW_API_WEBHOOK_SECRET=...
# NEW_API_GATEWAY_ENABLED=true
