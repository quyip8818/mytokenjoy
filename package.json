{
  "name": "tokenjoy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "pnpm start",
    "start": "pnpm start:postgres && concurrently --kill-others-on-fail -n backend,frontend -c blue,green \"pnpm -F @tokenjoy/backend start\" \"pnpm start:frontend\"",
    "docker:reset": "docker compose -f apps/newapi/docker-compose.yml down -v && docker compose -f apps/newapi/docker-compose.yml up postgres -d --wait",
    "start:postgres": "docker compose -f apps/newapi/docker-compose.yml up postgres -d --wait",
    "start:frontend": "wait-on -t 30000 http://127.0.0.1:8080/healthz && pnpm -F @tokenjoy/frontend start",
    "start:relay": "docker compose -f apps/newapi/docker-compose.yml up",
    "generate:permissions": "pnpm -F @tokenjoy/contracts generate",
    "gate:verify": "apps/newapi/scripts/gate-verify.sh",
    "build": "pnpm -F @tokenjoy/frontend build",
    "lint": "pnpm -r --parallel lint",
    "format": "prettier --write . && pnpm -F @tokenjoy/backend format",
    "test": "pnpm -r --parallel test",
    "test:all": "pnpm -r --parallel test:nocache",
    "test:e2e": "pnpm -F @tokenjoy/frontend test:e2e",
    "test:newapi-management": "apps/newapi/scripts/test-management.sh",
    "verify": "pnpm lint && pnpm test && pnpm test:newapi-management && pnpm build && pnpm -F @tokenjoy/backend build:check"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.8.4",
    "wait-on": "^8.0.3"
  }
}
