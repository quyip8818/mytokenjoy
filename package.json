{
  "name": "tokenjoy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "pnpm start",
    "start": "bash scripts/dev.sh start",
    "start:lite": "bash scripts/dev.sh lite",
    "docker:reset": "bash scripts/dev.sh reset",
    "reset": "bash scripts/dev.sh reset",
    "bootstrap": "apps/newapi/scripts/bootstrap-local-after-reset.sh",
    "infra": "bash scripts/dev.sh infra",
    "verify": "bash scripts/verify.sh",
    "build": "pnpm -F @tokenjoy/frontend build",
    "lint": "pnpm -r --parallel lint",
    "format": "prettier --write apps && pnpm -F @tokenjoy/backend format",
    "test": "bash scripts/dev.sh test",
    "test:e2e": "pnpm -F @tokenjoy/frontend test:e2e",
    "generate:permissions": "pnpm -F @tokenjoy/contracts generate"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.8.4",
    "wait-on": "^8.0.3"
  }
}
