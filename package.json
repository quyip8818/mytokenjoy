{
  "name": "tokenjoy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "pnpm start",
    "start:lite": "pnpm start:postgres && concurrently --kill-others-on-fail -n backend,frontend -c blue,green \"pnpm -F @tokenjoy/backend start\" \"pnpm start:frontend\"",
    "start": "pnpm start:infra && concurrently --kill-others-on-fail -n backend,frontend,mock -c blue,green,magenta \"pnpm -F @tokenjoy/backend start\" \"pnpm start:frontend\" \"pnpm start:dev-mock\"",
    "docker:reset": "docker compose -f apps/newapi/docker-compose.yml down -v && docker compose -f apps/newapi/docker-compose.yml up postgres -d --wait && pnpm bootstrap:local",
    "bootstrap:local": "apps/newapi/scripts/bootstrap-local-after-reset.sh",
    "bootstrap:token": "apps/newapi/scripts/bootstrap-local-after-reset.sh --token-only",
    "start:infra": "apps/newapi/scripts/start-infra.sh",
    "start:postgres": "docker compose -f apps/newapi/docker-compose.yml up postgres -d --wait",
    "start:redis": "docker compose -f apps/newapi/docker-compose.yml up redis -d --wait",
    "start:frontend": "wait-on -t 30000 http://127.0.0.1:8080/healthz && pnpm -F @tokenjoy/frontend start",
    "start:dev-mock": "pnpm -F @tokenjoy/dev-mock-llm start",
    "start:newapi": "docker compose -f apps/newapi/docker-compose.yml up",
    "generate:permissions": "pnpm -F @tokenjoy/contracts generate",
    "verify:gate": "apps/newapi/scripts/gate-verify.sh",
    "verify:integration": "apps/newapi/scripts/integration-verify.sh",
    "build": "pnpm -F @tokenjoy/frontend build",
    "lint": "pnpm -r --parallel lint",
    "format": "prettier --write apps && pnpm -F @tokenjoy/backend format",
    "test": "pnpm start:postgres && pnpm -r --parallel test",
    "test:all": "pnpm start:postgres && pnpm -r --parallel test:nocache",
    "test:e2e": "pnpm -F @tokenjoy/frontend test:e2e",
    "test:newapi-management": "apps/newapi/scripts/test-management.sh",
    "verify": "pnpm lint && pnpm test && pnpm build && pnpm -F @tokenjoy/backend build:check"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.8.4",
    "wait-on": "^8.0.3"
  }
}
