{
  "name": "tokenjoy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "start": "pnpm --filter @tokenjoy/frontend start",
    "build": "pnpm --filter @tokenjoy/frontend build",
    "build:gh-pages": "pnpm --filter @tokenjoy/frontend build:gh-pages",
    "lint": "pnpm --filter @tokenjoy/frontend lint",
    "format": "prettier --write .",
    "preview": "pnpm --filter @tokenjoy/frontend preview",
    "test": "pnpm --filter @tokenjoy/frontend test:run"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
