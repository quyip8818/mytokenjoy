{
  "name": "tokenjoy",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "start": "concurrently -n backend,frontend -c blue,green \"pnpm start:backend\" \"wait-on -t 30000 http://127.0.0.1:8080/healthz && cross-env VITE_ENABLE_MOCKS=false VITE_API_PROXY_TARGET=http://localhost:8080 pnpm --filter @tokenjoy/frontend start\"",
    "start:frontend": "pnpm --filter @tokenjoy/frontend start",
    "start:backend": "cd apps/backend && go run ./cmd/server",
    "start:relay": "docker compose -f apps/newapi/docker-compose.yml up",
    "gate:verify": "apps/newapi/scripts/gate-verify.sh",
    "build": "pnpm --filter @tokenjoy/frontend build",
    "build:gh-pages": "pnpm --filter @tokenjoy/frontend build:gh-pages",
    "lint": "pnpm --filter @tokenjoy/frontend lint && pnpm lint:backend",
    "lint:backend": "cd apps/backend && make lint",
    "format": "prettier --write . && pnpm format:backend",
    "format:backend": "cd apps/backend && make format",
    "test": "pnpm test:frontend && pnpm test:backend",
    "test:frontend": "pnpm --filter @tokenjoy/frontend test:run",
    "test:backend": "cd apps/backend && make test-unit",
    "test:backend:unit": "cd apps/backend && make test-unit",
    "test:backend:integration": "cd apps/backend && make test-integration"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "prettier": "^3.8.4",
    "wait-on": "^8.0.3"
  }
}
